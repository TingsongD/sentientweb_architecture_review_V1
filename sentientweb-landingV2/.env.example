# Canonical site URL for metadata, Open Graph, sitemap, and JSON-LD (no trailing slash).
# Required for production-style builds and primary production deployments.
# Preview deployments may still use provider preview hosts when this is unset.
NEXT_PUBLIC_SITE_URL=https://www.example.com

# Public Calendly event URL used for demo booking. If unset, the site falls back
# to the default SentientWeb booking URL configured in src/config/site.ts.
NEXT_PUBLIC_CALENDLY_EVENT_URL=https://calendly.com/example/demo

# Backend-owned widget embed. Set these to use the same third-party install path
# on the marketing site that customer websites use.
NEXT_PUBLIC_SENTIENT_WIDGET_ORIGIN=https://backend.example.com
NEXT_PUBLIC_SENTIENT_INSTALL_KEY=sw_inst_example
