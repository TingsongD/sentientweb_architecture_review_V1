{
  "name": "sentientweb-agent",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "scripts": {
    "build": "npm run build:web && npm run build:worker",
    "build:web": "npm run prisma:generate && react-router build",
    "build:worker": "npm run prisma:generate && esbuild app/worker.ts --bundle --platform=node --target=node20 --format=esm --outfile=build/worker/index.js --external:\"@prisma/client\" --external:\"bullmq\" --external:\"ioredis\" --external:\"pdf-parse\" --external:\"cheerio\" --external:\"openai\" --external:\"@google/generative-ai\"",
    "dev": "react-router dev",
    "migrate:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "render:predeploy": "npm run migrate:deploy",
    "start": "npm run start:web",
    "start:web": "START_WORKER=false react-router-serve ./build/server/index.js",
    "start:worker": "START_WORKER=true node ./build/worker/index.js",
    "setup": "npm run prisma:generate && npm run migrate:deploy",
    "prisma": "prisma",
    "secrets:reencrypt": "node ./scripts/reencrypt-secrets.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "react-router typegen && tsc --noEmit",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint ."
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.16.3",
    "@react-router/dev": "^7.9.3",
    "@react-router/fs-routes": "^7.9.3",
    "@react-router/node": "^7.9.3",
    "@react-router/serve": "^7.9.3",
    "bullmq": "^5.58.2",
    "cheerio": "^1.1.2",
    "ioredis": "^5.8.2",
    "isbot": "^5.1.31",
    "js-tiktoken": "^1.0.21",
    "openai": "^6.9.1",
    "pdf-parse": "^1.1.1",
    "prisma": "^6.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.9.3",
    "robots-parser": "^3.0.1",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "@types/node": "^22.18.8",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "esbuild": "^0.27.7",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vite": "^6.3.6",
    "vitest": "^3.2.4"
  },
  "author": "tingsongdai"
}
